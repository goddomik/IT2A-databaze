<Window x:Class="databaze_projekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:databaze_projekt"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- DataGrid -->
        <DataGrid x:Name="dgMikiny"
                  ItemsSource="{Binding Mikiny}"

                  Grid.Column="0"

                  Margin="0,0,10,0"

                  AutoGenerateColumns="False"

                  CanUserAddRows="False"

                  IsReadOnly="True"

                  SelectionMode="Single"

                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Značka" Binding="{Binding Znacka}" Width="*"/>
                <DataGridTextColumn Header="Velikost" Binding="{Binding Velikost}" Width="*"/>
                <DataGridTextColumn Header="Barva" Binding="{Binding Barva}" Width="100"/>
                <DataGridTextColumn Header="Cena" Binding="{Binding Cena}" Width="100"/>
                <DataGridCheckBoxColumn Header="Skladem" Binding="{Binding Skladem}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Pravý panel -->
        <StackPanel Grid.Column="1">

            <TextBlock Text="Evidence kopaček"

                       FontSize="18"

                       FontWeight="Bold"

                       Margin="0,0,0,10"/>

            <TextBlock Text="Značka:"/>
            <TextBox x:Name="tbZnacka" Margin="0,0,0,8"/>

            <TextBlock Text="Velikost:"/>
            <TextBox x:Name="tbVelikost" Margin="0,0,0,8"/>

            <TextBlock Text="Barva:"/>
            <TextBox x:Name="tbBarva" Margin="0,0,0,8"/>

            <TextBlock Text="Cena:"/>
            <TextBox x:Name="tbCena" Margin="0,0,0,8"/>

            <CheckBox x:Name="cbSkladem"

                      Content="Skladem"

                      Margin="0,0,0,10"/>

            <Button Content="Přidat Mikinu" Margin="0,5" Click="Button_Click"/>
            <Button Content="Načíst vybrané do formuláře" Margin="0,5" Click="Button_Click"/>
            <Button Content="Upravit vybranou mikinu" Margin="0,5" Click="Button_Click"/>
            <Button Content="Smazat vybranou mikinu" Margin="0,5" Click="Button_Click"/>
            <Button Content="Vyčistit formulář" Margin="0,5" Click="Button_Click"/>

        </StackPanel>
    </Grid>

</Window>
